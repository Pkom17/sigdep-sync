# Build artefacts
target/
*.class
*.jar

# Side-checkout of sigdep-contracts done by the CI inside the workspace
# (actions/checkout refuses paths outside the workspace).
.sigdep-contracts/

# Local SQLite buffer (per-site sync state — never commit). Only the
# top-level buffer/ directory; the Java package src/.../sync/buffer/
# must not be matched.
*.sqlite
*.db
/buffer/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Secrets — never commit. Use .env.example as a template.
.env
.env.local
.env.*.local

# Logs
*.log
