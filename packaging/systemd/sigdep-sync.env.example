# Copy to /etc/sigdep-sync/sigdep-sync.env on the site machine and fill in the values.

SIGDEP_SITE_CODE=ABJ-CHU-YOPOUGON

SIGDEP_LOCAL_DB_URL=jdbc:mysql://localhost:3306/openmrs?readOnly=true&useSSL=false
SIGDEP_LOCAL_DB_USER=sigdep_reader
SIGDEP_LOCAL_DB_PASSWORD=changeme

SIGDEP_BUFFER_PATH=/var/lib/sigdep-agent/buffer.sqlite

SIGDEP_CENTRAL_API_URL=https://api.sigdep.sante.gouv.ci
SIGDEP_KEYCLOAK_URL=https://auth.sigdep.sante.gouv.ci
SIGDEP_KEYCLOAK_CLIENT_ID=sigdep-agent
SIGDEP_KEYCLOAK_CLIENT_SECRET=changeme

SIGDEP_SYNC_INTERVAL_MINUTES=15
SIGDEP_BATCH_SIZE=500

# OkHttp timeouts vers le hub (en secondes).
# Augmenter SIGDEP_HTTP_READ_TIMEOUT_SECONDS et WRITE_TIMEOUT_SECONDS
# sur les sites avec un gros backfill (LAB_RESULTS, plusieurs
# milliers de lignes) ou un lien réseau lent.
#SIGDEP_HTTP_CONNECT_TIMEOUT_SECONDS=10
#SIGDEP_HTTP_READ_TIMEOUT_SECONDS=60
#SIGDEP_HTTP_WRITE_TIMEOUT_SECONDS=60
