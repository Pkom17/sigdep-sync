REM ============================================================
REM  Configuration agent SIGDEP-3 (Windows) - copier en .env et
REM  completer. spring-dotenv lit ce fichier automatiquement au
REM  demarrage du JAR.
REM
REM  Ne pas mettre de guillemets autour des valeurs, ne pas mettre
REM  d'espaces autour des =.
REM ============================================================

REM ---- Identification du site ----
SIGDEP_SITE_CODE=ABJ-CHU-YOPOUGON

REM ---- OpenMRS local (MySQL, lecture seule) ----
REM Sur le poste qui execute MySQL : localhost
REM Sur une autre machine du LAN     : IP ou hostname
SIGDEP_LOCAL_DB_URL=jdbc:mysql://localhost:3306/openmrs?readOnly=true&useSSL=false
SIGDEP_LOCAL_DB_USER=sigdep_reader
SIGDEP_LOCAL_DB_PASSWORD=changeme

REM ---- Buffer SQLite local (chemin Windows) ----
REM Recommande : un dossier dedie sous C:\ ou D:\, hors Program Files
REM (Program Files demande des droits admin pour ecrire).
SIGDEP_BUFFER_PATH=C:\sigdep-sync\buffer.sqlite

REM ---- Hub central ----
SIGDEP_CENTRAL_API_URL=https://api.sigdep.sante.gouv.ci

REM ---- Authentification (cle API du site, en-tete X-API-Key) ----
REM Generee dans la console du hub (page Sites), affichee 1x seulement.
SIGDEP_API_KEY=changeme

REM ---- Cadence + tuning ----
SIGDEP_SYNC_INTERVAL_MINUTES=15
SIGDEP_BATCH_SIZE=500
SIGDEP_MAX_REJECT_ATTEMPTS=10

REM ---- OkHttp timeouts (decommenter si besoin) ----
REM Sur les sites avec un gros backfill (plusieurs milliers de lab
REM results) augmenter READ et WRITE :
REM SIGDEP_HTTP_CONNECT_TIMEOUT_SECONDS=10
REM SIGDEP_HTTP_READ_TIMEOUT_SECONDS=300
REM SIGDEP_HTTP_WRITE_TIMEOUT_SECONDS=300
