# SIGDEP-3 edge agent — configuration (Linux). Copier en .env et compléter.
# install.sh place ce fichier dans /opt/sigdep-sync/.env. Le JRE est embarqué :
# pas de JAVA_HOME à renseigner.

# ---- Identité du site (OBLIGATOIRE) ---------------------------------------
# Identifiant unique de l'établissement (doit exister dans core.sites du hub).
SIGDEP_SITE_CODE=

# ---- Base OpenMRS locale (MySQL, lecture seule) ---------------------------
SIGDEP_LOCAL_DB_URL=jdbc:mysql://localhost:3306/openmrs?readOnly=true&useSSL=false
SIGDEP_LOCAL_DB_USER=sigdep_reader
SIGDEP_LOCAL_DB_PASSWORD=

# ---- Buffer SQLite local (outbox + watermarks) ----------------------------
# Le service tourne sous l'utilisateur 'sigdep-sync' qui possède ce dossier.
SIGDEP_BUFFER_PATH=/var/lib/sigdep-sync/buffer.sqlite

# ---- Hub central ----------------------------------------------------------
# URL publique du hub SIGDEP (HTTPS en production).
SIGDEP_CENTRAL_API_URL=https://sigdephub.itech-civ.org
# Clé API du site, générée sur la console (page Sites → Générer une clé),
# affichée une seule fois. Envoyée en en-tête X-API-Key.
SIGDEP_API_KEY=

# ---- Réglages de synchronisation ------------------------------------------
SIGDEP_SYNC_INTERVAL_MINUTES=15
SIGDEP_BATCH_SIZE=500
SIGDEP_MAX_REJECT_ATTEMPTS=10
