# =============================================================================
# Configuration agent SIGDEP-3 — copier en .env et compléter.
#
# Toutes ces variables sont lues par l'application Spring Boot au démarrage
# (via spring-dotenv). Les variables non renseignées prennent les valeurs
# par défaut définies dans application.yml.
# =============================================================================

# ---- Identification du site ------------------------------------------------
# Code unique du site, doit exister dans la table core.sites du hub.
SIGDEP_SITE_CODE=ABJ-CHU-YOPOUGON

# ---- OpenMRS local (MySQL, lecture seule) ---------------------------------
# Selon votre scénario réseau, ajustez l'host :
#   - Scénario 1 (OpenMRS sur l'hôte)  : host.docker.internal
#   - Scénario 2 (autre container)     : nom du container MySQL
#   - Scénario 3 (machine distante)    : IP ou hostname
SIGDEP_LOCAL_DB_URL=jdbc:mysql://host.docker.internal:3306/openmrs?readOnly=true&useSSL=false
SIGDEP_LOCAL_DB_USER=sigdep_reader
SIGDEP_LOCAL_DB_PASSWORD=changeme

# ---- Buffer SQLite local (persisté via le volume Docker) ------------------
# Garder le défaut sauf besoin spécifique. Le volume sigdep-buffer dans le
# compose pointe sur /var/lib/sigdep-agent.
SIGDEP_BUFFER_PATH=/var/lib/sigdep-agent/buffer.sqlite

# ---- Hub central (production) ---------------------------------------------
SIGDEP_CENTRAL_API_URL=https://api.sigdep.sante.gouv.ci

# ---- Authentification (clé API du site, en-tête X-API-Key) ----------------
# Générée dans la console du hub (page Sites → « Gérer »), affichée 1× seulement.
SIGDEP_API_KEY=changeme

# ---- Cadence + tuning -----------------------------------------------------
SIGDEP_SYNC_INTERVAL_MINUTES=15
SIGDEP_BATCH_SIZE=500
SIGDEP_MAX_REJECT_ATTEMPTS=10

# ---- OkHttp timeouts ------------------------------------------------------
# Augmenter SIGDEP_HTTP_READ_TIMEOUT_SECONDS et WRITE_TIMEOUT_SECONDS sur
# les sites avec un gros backfill (LAB_RESULTS, plusieurs milliers de
# lignes) ou un lien réseau lent.
#SIGDEP_HTTP_CONNECT_TIMEOUT_SECONDS=10
#SIGDEP_HTTP_READ_TIMEOUT_SECONDS=60
#SIGDEP_HTTP_WRITE_TIMEOUT_SECONDS=60

# ---- Tag de l'image Docker -------------------------------------------------
# Optionnel ; par défaut "latest". Pour épingler une version :
#SIGDEP_SYNC_TAG=1.0.1
