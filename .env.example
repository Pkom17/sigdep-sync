# SIGDEP-3 edge agent — environment configuration template.
# Copy to .env and fill in the real values for this site.
# This file is also the source of truth for systemd's EnvironmentFile=.

# ----------------------------------------------------------------------------
# Site identity (REQUIRED) — DHIS2 "Identifiant Unique Etablissement"
# Must match a row in core.sites on the central hub.
# ----------------------------------------------------------------------------
SIGDEP_SITE_CODE=

# ----------------------------------------------------------------------------
# Local OpenMRS MySQL (read-only)
# ----------------------------------------------------------------------------
SIGDEP_LOCAL_DB_URL=jdbc:mysql://localhost:3306/openmrs?readOnly=true&useSSL=false
SIGDEP_LOCAL_DB_USER=sigdep_reader
SIGDEP_LOCAL_DB_PASSWORD=

# ----------------------------------------------------------------------------
# Local SQLite buffer (outbox + watermarks)
# Linux/macOS default: /var/lib/sigdep-agent/buffer.sqlite
# Windows example:     C:/ProgramData/sigdep-agent/buffer.sqlite
# ----------------------------------------------------------------------------
SIGDEP_BUFFER_PATH=/var/lib/sigdep-agent/buffer.sqlite

# ----------------------------------------------------------------------------
# Central hub
# ----------------------------------------------------------------------------
SIGDEP_CENTRAL_API_URL=http://localhost:8090

# ----------------------------------------------------------------------------
# Keycloak (only used when sigdep.sync.auth.mode != none)
# ----------------------------------------------------------------------------
SIGDEP_KEYCLOAK_URL=http://localhost:8180
SIGDEP_KEYCLOAK_CLIENT_ID=sigdep-agent
SIGDEP_KEYCLOAK_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Scheduling and batch sizing
# ----------------------------------------------------------------------------
SIGDEP_SYNC_INTERVAL_MINUTES=15
SIGDEP_BATCH_SIZE=500
