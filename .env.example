# SIGDEP-3 edge agent — environment configuration template.
# Copy to .env and fill in the real values for this site.
# This file is also the source of truth for systemd's EnvironmentFile=.

# ----------------------------------------------------------------------------
# Java runtime (REQUIRED — must be JDK 17 or newer)
# run.sh / run.bat will use this if set; otherwise on macOS they try
# /usr/libexec/java_home -v 17 and fall back to whatever 'java' is on PATH.
# Examples:
#   macOS Homebrew  : /opt/homebrew/opt/openjdk@17
#   Ubuntu/Debian   : /usr/lib/jvm/java-17-openjdk-amd64
#   Windows         : C:\Program Files\Eclipse Adoptium\jdk-17.0.13-hotspot
# ----------------------------------------------------------------------------
JAVA_HOME=

# ----------------------------------------------------------------------------
# Site identity (REQUIRED) — DHIS2 "Identifiant Unique Etablissement"
# Must match a row in core.sites on the central hub.
# ----------------------------------------------------------------------------
SIGDEP_SITE_CODE=

# ----------------------------------------------------------------------------
# Local OpenMRS MySQL (read-only)
# ----------------------------------------------------------------------------
SIGDEP_LOCAL_DB_URL=jdbc:mysql://localhost:3306/openmrs?readOnly=true&useSSL=false
SIGDEP_LOCAL_DB_USER=sigdep_reader
SIGDEP_LOCAL_DB_PASSWORD=

# ----------------------------------------------------------------------------
# Local SQLite buffer (outbox + watermarks)
# Linux/macOS default: /var/lib/sigdep-agent/buffer.sqlite
# Windows example:     C:/ProgramData/sigdep-agent/buffer.sqlite
# ----------------------------------------------------------------------------
SIGDEP_BUFFER_PATH=/var/lib/sigdep-agent/buffer.sqlite

# ----------------------------------------------------------------------------
# Central hub
# ----------------------------------------------------------------------------
SIGDEP_CENTRAL_API_URL=http://localhost:8090

# ----------------------------------------------------------------------------
# Authentification (auth v2.0) : clé API du site, envoyée en X-API-Key.
# Générée dans la console (page Sites → « Gérer » → « Générer une clé »),
# affichée une seule fois. Laisser vide si l'ingestion-api tourne en
# profil dev (auth désactivée sur /api/v1/sync/**).
# ----------------------------------------------------------------------------
SIGDEP_API_KEY=

# ----------------------------------------------------------------------------
# Scheduling and batch sizing
# ----------------------------------------------------------------------------
SIGDEP_SYNC_INTERVAL_MINUTES=15
SIGDEP_BATCH_SIZE=500

# Retries for hub-side rejects before a row sticks in DEAD_LETTER (then
# needs an admin action via the console). Keep it high enough to outlast
# initial backfill FK ordering issues (UNKNOWN_PATIENT) but low enough to
# surface genuinely bad data.
SIGDEP_MAX_REJECT_ATTEMPTS=10
